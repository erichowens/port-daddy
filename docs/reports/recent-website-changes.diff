-    </div>
-  </section>
-
-  <div class="content-layout">
-    <aside class="toc">
-      <h4>On this page</h4>
-      <ul>
-        <li><a href="#what-are-harbors">What Are Harbors?</a></li>
-        <li><a href="#creating">Creating a Harbor</a></li>
-        <li><a href="#issuing-tokens">Issuing Tokens</a></li>
-        <li><a href="#capabilities">Capability Reference</a></li>
-        <li><a href="#scoping">Scoping Operations</a></li>
-        <li><a href="#sdk">SDK Equivalent</a></li>
-      </ul>

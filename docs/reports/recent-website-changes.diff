-        <thead>
-          <tr><th>Phase</th><th>When to use it</th></tr>
-        </thead>
-        <tbody>
-          <tr>
-            <td><code>planning</code></td>
-            <td>Designing the approach, writing specs, deciding which files to touch</td>
-          </tr>
-          <tr>
-            <td><code>in_progress</code></td>
-            <td>Actively writing code, making changes, executing the plan</td>
-          </tr>
-          <tr>
-            <td><code>testing</code></td>
-            <td>Running the test suite, fixing failures, verifying behavior</td>
-          </tr>
-          <tr>
-            <td><code>reviewing</code></td>
-            <td>Code review in progress, waiting for human approval or another agent's critique</td>
-          </tr>
-          <tr>
-            <td><code>completed</code></td>
-            <td>Work merged or definitively done -- set automatically by <code>pd done</code></td>
-          </tr>
-          <tr>
-            <td><code>abandoned</code></td>
-            <td>Work stopped due to a blocker -- triggers salvage so another agent can continue</td>
-          </tr>
-        </tbody>

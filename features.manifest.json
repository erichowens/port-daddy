    "tutorial": {
      "description": "Interactive tutorial — learn Port Daddy step by step",
      "cli": ["learn", "tutorial"],
      "sdk": [],
      "routes": [],
      "completions": ["learn", "tutorial"],
      "docs": { "readme": false, "sdk": false }
    }
  }
}

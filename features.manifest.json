    "sugar": {
      "description": "Compound commands for common workflows (begin/done/whoami)",
      "cli": ["begin", "b", "done", "whoami", "w", "with-lock", "n", "u", "d"],
      "sdk": ["begin", "done", "whoami"],
      "routes": ["POST /sugar/begin", "POST /sugar/done", "GET /sugar/whoami"],
      "completions": ["begin", "b", "done", "whoami", "w", "with-lock"],
      "docs": { "readme": false, "sdk": false }

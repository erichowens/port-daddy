      "description": "Local DNS records for services (.local hostnames)",
      "cli": ["dns"],
      "sdk": ["dnsRegister", "dnsUnregister", "dnsList", "dnsGet", "dnsCleanup", "dnsStatus"],
      "routes": ["POST /dns/:param", "DELETE /dns/:param", "GET /dns", "GET /dns/status", "GET /dns/:param", "POST /dns/cleanup"],
      "completions": ["dns"],
      "docs": { "readme": true, "sdk": true }
    },
    "wait": {
      "description": "Wait for services to become available",
      "cli": ["wait"],
      "sdk": ["waitForService", "waitForServices"],
      "routes": ["GET /wait/:param", "POST /wait"],
      "completions": ["wait"],
      "docs": { "readme": true, "sdk": true }

    "session_phases": {
      "description": "Session lifecycle phases (planning/in_progress/testing/reviewing/completed/abandoned)",
      "cli": [],
      "sdk": [],
      "routes": ["PUT /sessions/:param/phase"],
      "completions": [],
      "docs": { "readme": false, "sdk": false },
      "_note": "Phase is set via MCP tool or API, no dedicated CLI command"
    },
    "file_claims": {
      "description": "Global file claim view across all sessions",
      "cli": ["files", "who-owns"],
      "sdk": [],
      "routes": ["GET /files", "GET /files/who-owns"],
      "completions": ["files", "who-owns"],
      "docs": { "readme": false, "sdk": false }
    },
    "integration_signals": {
      "description": "Integration signals via pub/sub (ready/needs)",
      "cli": ["integration"],
      "sdk": [],
      "routes": [],
      "completions": ["integration"],
      "docs": { "readme": false, "sdk": false },
      "_note": "Routes are messaging routes reused with integration: prefix channels"
    },
    "briefing": {
      "description": "Project-local agent intelligence (.portdaddy/ briefing)",
      "cli": ["briefing", "history"],
      "sdk": ["generateBriefing", "getBriefing", "getProjectHistory"],
      "routes": ["POST /briefing", "GET /briefing/:param"],
      "completions": ["briefing", "history"],
      "docs": { "readme": false, "sdk": false }
